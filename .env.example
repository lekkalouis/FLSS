# FLSS environment example
# Copy this file to .env and fill in only the integrations and features you use.

# Core server and frontend access
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# Shopify customer account portal auth
SHOPIFY_CUSTOMER_ACCOUNT_DOMAIN=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=
SHOPIFY_CUSTOMER_ACCOUNT_SCOPES=openid email customer-account-api:full
SHOPIFY_CUSTOMER_ACCOUNT_REDIRECT_URI=
SHOPIFY_CUSTOMER_ACCOUNT_POST_LOGOUT_REDIRECT_URI=
SHOPIFY_CUSTOMER_ACCOUNT_COOKIE_SECURE=false
SHOPIFY_CUSTOMER_ACCOUNT_SESSION_TTL_MS=28800000

# ParcelPerfect
PP_BASE_URL=
PP_TOKEN=
PP_REQUIRE_TOKEN=true
PP_ACCNUM=
PP_PLACE_ID=
PP_TIMEOUT_MS=10000

# Shopify, pricing, and delivery flows
SHOPIFY_STORE=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
DELIVERY_CODE_SECRET=
SHOPIFY_API_VERSION=2025-10
SHOPIFY_FLOW_TAG=dispatch_flow
SHOPIFY_TIMEOUT_MS=10000
SHOPIFY_THROTTLE_MAX_CONCURRENCY=4
SHOPIFY_THROTTLE_BASE_DELAY_MS=250
SHOPIFY_THROTTLE_MAX_DELAY_MS=5000
SHOPIFY_THROTTLE_CALL_LIMIT_RATIO=0.85
TRACKING_COMPANY=SWE / ParcelPerfect

# PrintNode
PRINTNODE_API_KEY=
PRINTNODE_PRINTER_ID=
PRINTNODE_DELIVERY_NOTE_PRINTER_ID=
PRINTNODE_DELIVERY_NOTE_PRINTER_IDS=
PRINTNODE_TIMEOUT_MS=10000

# Maps
GOOGLE_MAPS_API_KEY=

# SMTP and notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=
TRUCK_EMAIL_TO=

# Local storage and generated assets
LOCAL_DB_PATH=data/flss-products.sqlite
ASSETS_PATH=data/assets
BACKUPS_PATH=data/backups
SYNC_ENABLED=true

# Dispatch controller auth and telemetry
ROTARY_TOKEN=
ROTARY_DEBOUNCE_MS=40
REMOTE_TOKEN=
REMOTE_HEARTBEAT_STALE_MS=30000

# Environment telemetry thresholds
ENV_TEMP_MIN_C=5
ENV_TEMP_MAX_C=35
ENV_HUMIDITY_MIN=20
ENV_HUMIDITY_MAX=70
ENV_STALE_MS=60000

# UI defaults projected by /api/v1/config
UI_COST_ALERT_THRESHOLD=250
UI_BOOKING_IDLE_MS=6000
UI_TRUCK_ALERT_THRESHOLD=25
UI_BOX_DIM_1=40
UI_BOX_DIM_2=30
UI_BOX_DIM_3=30
UI_BOX_MASS_KG=5
UI_ORIGIN_PERSON=
UI_ORIGIN_ADDR1=
UI_ORIGIN_ADDR2=
UI_ORIGIN_ADDR3=
UI_ORIGIN_ADDR4=
UI_ORIGIN_POSTCODE=
UI_ORIGIN_TOWN=
UI_ORIGIN_PLACE_ID=
UI_ORIGIN_CONTACT=
UI_ORIGIN_PHONE=
UI_ORIGIN_CELL=
UI_ORIGIN_NOTIFY=1
UI_ORIGIN_EMAIL=
UI_ORIGIN_NOTES=
UI_FEATURE_MULTI_SHIP=true

# Optional GitHub webhook auto-update
GITHUB_WEBHOOK_SECRET=

# Raspberry Pi wired controller client
FLSS_BASE_URL=http://127.0.0.1:3000/api/v1

# Compatibility / CI metadata variables
PR_NUMBER=
GITHUB_PR_NUMBER=
GITHUB_REF=
PR_URL=
GITHUB_SERVER_URL=https://github.com
GITHUB_REPOSITORY=
PR_TITLE=
GITHUB_PR_TITLE=
GITHUB_ACTOR=
